# Copy to .env and adjust values. Do not commit .env.

# --- Docker / MySQL (docker-compose) ---
DB_NAME=wp-portfolio
DB_USER=admin
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme_root

# Container names
DB_CONTAINER=portfolio_db
WP_CONTAINER=portfolio_app

# Backup directories (relative to project root)
DB_BACKUP_DIR=db_backups
UPLOADS_BACKUP_DIR=uploads_backups

# Public WordPress URL (used in WORDPRESS_CONFIG_EXTRA)
WP_URL=http://localhost

# --- PHPUnit / wp-tests-config.php (optional overrides) ---
# Used when running tests on the host; docker-compose wp-tests sets these for container runs.
# WP_CORE_DIR=/absolute/path/to/wordpress
# WP_TEST_DB_HOST=127.0.0.1
# WP_TEST_DB_NAME=wordpress_test
# WP_TEST_DB_USER=root
# WP_TEST_DB_PASSWORD=password
# WP_TEST_TABLE_PREFIX=wptests_
# WP_TESTS_DOMAIN=portfolio.tests
# WP_TESTS_EMAIL=you@example.com
# WP_TESTS_TITLE=Portfolio Test Suite
# WP_PHP_BINARY=/opt/homebrew/bin/php
